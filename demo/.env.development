# Local dev only (loaded by `vite` in development mode). Storybook runs on its
# own port here — `pnpm storybook` serves it at :6006 — so point the links at
# it directly. The production build ignores this file and falls back to the
# `/storybook/` path published next to the demo on GitHub Pages.
VITE_STORYBOOK_HOST=http://localhost:6006
